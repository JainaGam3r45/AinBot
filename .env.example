BOT_TOKEN="<your-token-bot>"
PREFIX="<your-prefix-bot>"
DEVELOPERS_IDS= [ "<your-developer-id>" ]

# Database provider.
# Use "none" to keep the bot running without persistence.
# Use "memory" for local tests only; data is lost when the process restarts.
# Use "sqlite" for small or medium single-instance bots.
# Use "postgresql" for production bots that may grow into shards or multiple processes.
# Use "mysql", "mariadb", or "mongodb" when you already use that database elsewhere.
# Supported values: none | memory | sqlite | mysql | mariadb | mongodb | postgresql
DATABASE_PROVIDER="none"

# Connection URL. Preferred for hosted databases and production deployments.
# Examples:
# DATABASE_URL="postgres://user:password@localhost:5432/ainbot"
# DATABASE_URL="mysql://user:password@localhost:3306/ainbot"
# DATABASE_URL="mongodb://user:password@localhost:27017/ainbot"
DATABASE_URL=""

# Manual connection settings. Used when DATABASE_URL is empty.
DATABASE_HOST="localhost"
DATABASE_PORT=""
DATABASE_USER=""
DATABASE_PASSWORD=""
DATABASE_NAME="ainbot"

# SQLite only. The file is created automatically when the sqlite driver is installed.
DATABASE_PATH="data/ainbot.sqlite"

# SQL providers only. Keep this as a simple table name with letters, numbers, and underscores.
DATABASE_TABLE="ainbot_records"

# MongoDB only. Collection used to store bot records.
DATABASE_COLLECTION="ainbot_records"

# Enable this only when your database provider requires SSL/TLS.
DATABASE_SSL="false"
